@model ProductDetailViewModel
@{
    ViewData["Title"] = "Chi tiết mặt hàng";
}

<div class="breadcrumb-card">
    <div class="breadcrumb">Trang chủ / Sản phẩm / @Model.Product.ProductName</div>
</div>

<div class="product-detail-wrap">
    <div class="product-gallery">
        <div class="img-box">
            @{
                var mainPhoto = ProductPhotos.ResolveVirtualPath(Model.Product.Photo, Model.Product.ProductName);
            }
            @if (!string.IsNullOrWhiteSpace(mainPhoto))
            {
                <img src="@Url.Content(mainPhoto)"
                     alt="@Model.Product.ProductName"
                     class="img-fluid"
                     onerror="this.onerror=null; this.outerHTML='<div class=&quot;text-center text-muted&quot;><i class=&quot;bi bi-image fs-1&quot;></i></div>';" />
            }
            else
            {
                <div class="text-center text-muted">
                    <i class="bi bi-image fs-1"></i>
                </div>
            }
        </div>
    </div>

    <div class="product-info-card">
        <h3>@Model.Product.ProductName</h3>
        <div class="price">@Model.Product.Price.ToString("N0") đ</div>

        <div class="kv">
            <div class="k">Đơn vị tính</div>
            <div class="v">@Model.Product.Unit</div>

            <div class="k">Trạng thái</div>
            <div class="v" style="color:@(Model.Product.IsSelling ? "#16a34a" : "#dc2626")">
                @(Model.Product.IsSelling ? "Còn hàng" : "Tạm ngừng")
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Product.ProductDescription))
        {
            <div class="mt-3 text-muted" style="line-height:1.6">
                @Model.Product.ProductDescription
            </div>
        }

        <form asp-controller="Cart" asp-action="Add" method="post" class="mt-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="productID" value="@Model.Product.ProductID" />

            <div class="quantity-row">
                <label class="form-label mb-0 fw-bold" style="min-width:110px">Số lượng</label>
                <input type="number" name="quantity" value="1" min="1" class="form-control" style="width:140px" />
                <button type="submit" class="btn btn-shop-primary">
                    <i class="bi bi-cart-plus me-1"></i>
                    Thêm vào giỏ hàng
                </button>
            </div>
        </form>
    </div>
</div>

<div class="section-title">
    <div>
        <h4>Sản phẩm liên quan</h4>
        <div class="underline"></div>
    </div>
</div>

<div class="product-grid" style="grid-template-columns:repeat(4, 1fr);">
    @foreach (var rp in Model.RelatedProducts)
    {
        <div class="product-card">
            <div class="product-img">
                @{
                    var relPhoto = ProductPhotos.ResolveVirtualPath(rp.Photo, rp.ProductName);
                }
                @if (!string.IsNullOrWhiteSpace(relPhoto))
                {
                    <img src="@Url.Content(relPhoto)"
                         alt="@rp.ProductName"
                         onerror="this.onerror=null; this.outerHTML='<div class=&quot;text-center text-muted&quot;><i class=&quot;bi bi-image fs-1&quot;></i></div>';" />
                }
                else
                {
                    <div class="text-center text-muted">
                        <i class="bi bi-image fs-1"></i>
                    </div>
                }
            </div>
            <div class="content">
                <div class="name">@rp.ProductName</div>
                <div class="price">@rp.Price.ToString("N0") đ</div>
                <div class="unit">@rp.Unit</div>
                <div class="status">
                    @(rp.IsSelling ? "Còn hàng" : "Tạm ngừng")
                </div>
            </div>
            <div class="actions">
                <form asp-controller="Cart" asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productID" value="@rp.ProductID" />
                    <button type="submit" class="btn btn-shop-primary w-100">
                        <i class="bi bi-bag-plus me-1"></i>
                        Thêm
                    </button>
                </form>
            </div>
        </div>
    }
</div>

@if (Model.Attributes.Any())
{
    <div class="page-card mt-4">
        <h5 style="font-weight:900">Thông số / Thuộc tính</h5>
        <table class="table table-bordered mt-2">
            <tbody>
            @foreach (var attr in Model.Attributes)
            {
                <tr>
                    <th style="width: 35%">@attr.AttributeName</th>
                    <td>@attr.AttributeValue</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
