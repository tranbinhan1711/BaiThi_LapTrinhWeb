@model List<CartItemViewModel>
@{
    ViewData["Title"] = "Xác nhận xóa giỏ hàng";
    var total = Model.Sum(x => x.Amount);
    var lineCount = Model.Count;
    var qtySum = Model.Sum(x => x.Quantity);
}

<div class="breadcrumb-card">
    <div class="breadcrumb">Trang chủ / <a asp-action="Index" asp-controller="Cart" class="text-decoration-none text-body">Giỏ hàng</a> / Xác nhận xóa</div>
</div>

<div class="page-card">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="feature-ico" style="background:rgba(220,38,38,.1); color:#dc2626">
            <i class="bi bi-trash3"></i>
        </div>
        <div>
            <div style="font-weight:900;font-size:20px">Xóa toàn bộ giỏ hàng?</div>
            <div class="text-muted" style="margin-top:4px">
                Thao tác này sẽ gỡ tất cả sản phẩm khỏi giỏ. Bạn có thể thêm lại sau.
            </div>
        </div>
    </div>

    <div class="alert alert-warning border-0 mb-4" style="background:rgba(234,179,8,.12); color:#854d0e">
        <div class="d-flex gap-2 align-items-start">
            <i class="bi bi-exclamation-triangle-fill mt-1"></i>
            <div>
                <strong>Giỏ hiện có @lineCount mặt hàng (@qtySum sản phẩm).</strong>
                Tổng giá trị ước tính: <strong>@total.ToString("N0") đ</strong>.
            </div>
        </div>
    </div>

    <ul class="list-group list-group-flush border rounded mb-4 bg-white">
        @foreach (var item in Model)
        {
            <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                <div>
                    <div style="font-weight:700">@item.ProductName</div>
                    <div class="text-muted small">@item.Quantity × @item.Price.ToString("N0") đ</div>
                </div>
                <span style="font-weight:800">@item.Amount.ToString("N0") đ</span>
            </li>
        }
    </ul>

    <div class="d-flex flex-wrap gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-1"></i>
            Quay lại giỏ hàng
        </a>
        <form asp-action="Clear" method="post" class="d-inline">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-danger">
                <i class="bi bi-trash3 me-1"></i>
                Xóa toàn bộ giỏ
            </button>
        </form>
    </div>
</div>
