@{
    ViewData["Title"] = "Giới thiệu";
}

<div class="breadcrumb-card">
    <div class="breadcrumb">Trang chủ / Giới thiệu</div>
</div>

<div class="page-card">
    <div class="text-center">
        <h2 style="font-weight:900">Về TBA Shop</h2>
        <div class="text-muted" style="margin-top:6px">Nơi mua sắm đáng tin cậy của bạn</div>
    </div>

    <div class="row mt-4 g-3">
        <div class="col-md-4">
            <div class="feature-card h-100" style="box-shadow:none;background:#f8fafc;border:1px solid rgba(15,23,42,.06);">
                <div class="feature-ico">
                    <i class="bi bi-check2-circle"></i>
                </div>
                <div>
                    <h6>Hàng chính hãng</h6>
                    <p>100% sản phẩm có nguồn gốc rõ ràng</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card h-100" style="box-shadow:none;background:#f8fafc;border:1px solid rgba(15,23,42,.06);">
                <div class="feature-ico" style="background:rgba(13,110,253,.08)">
                    <i class="bi bi-truck"></i>
                </div>
                <div>
                    <h6>Giao hàng nhanh</h6>
                    <p>Giao toàn quốc trong 1–3 ngày</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card h-100" style="box-shadow:none;background:#f8fafc;border:1px solid rgba(15,23,42,.06);">
                <div class="feature-ico" style="background:rgba(245,158,11,.10); color:#f59e0b;">
                    <i class="bi bi-headset"></i>
                </div>
                <div>
                    <h6>Hỗ trợ 24/7</h6>
                    <p>Đội ngũ tư vấn sẵn sàng mọi lúc</p>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4" style="line-height:1.7;color:#334155">
        <h5 style="font-weight:900">Câu chuyện của chúng tôi</h5>
        <p class="mb-2">
            TBA Shop được thành lập với sứ mệnh mang đến cho khách hàng những sản phẩm chất lượng nhất
            với giá cả hợp lý.
        </p>
        <p class="mb-2">
            Chúng tôi tin rằng mỗi trải nghiệm mua sắm nên được tối ưu về chất lượng lẫn dịch vụ. Vì vậy,
            mọi nhân viên và hệ thống kho hàng đều được vận hành theo tiêu chuẩn nghiêm ngặt.
        </p>
        <p class="mb-0">
            TBA Shop - Mua sắm thông minh, sống chất lượng!
        </p>
    </div>
</div>

