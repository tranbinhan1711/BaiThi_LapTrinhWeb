@{
    ViewData["Title"] = "Liên hệ";
}

<div class="breadcrumb-card">
    <div class="breadcrumb">Trang chủ / Liên hệ</div>
</div>

<div class="page-card">
    <div class="text-center mb-4">
        <h2 style="font-weight:900">Liên hệ TBA Shop</h2>
        <div class="text-muted" style="margin-top:6px">
            Chúng tôi luôn sẵn sàng hỗ trợ bạn qua điện thoại, email hoặc biểu mẫu bên dưới.
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <div class="p-4" style="background:#fff;border:1px solid rgba(15,23,42,.06);border-radius:14px;box-shadow:var(--shop-shadow)">
                <h5 style="font-weight:900">Thông tin liên hệ</h5>
                <div class="mt-3" style="line-height:1.8;color:#334155">
                    <div class="d-flex gap-3 align-items-start">
                        <i class="bi bi-geo-alt-fill text-primary mt-1"></i>
                        <div>
                            <div style="font-weight:800">Địa chỉ</div>
                            <div class="text-muted">123 Nguyễn Văn Linh, Q. Hải Châu, TP. Đà Nẵng</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start mt-3">
                        <i class="bi bi-telephone-fill text-primary mt-1"></i>
                        <div>
                            <div style="font-weight:800">Điện thoại</div>
                            <div class="text-muted">0123.456.789</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start mt-3">
                        <i class="bi bi-envelope-fill text-primary mt-1"></i>
                        <div>
                            <div style="font-weight:800">Email</div>
                            <div class="text-muted">contact@lhkshop.vn</div>
                        </div>
                    </div>
                    <div class="d-flex gap-3 align-items-start mt-3">
                        <i class="bi bi-clock-fill text-primary mt-1"></i>
                        <div>
                            <div style="font-weight:800">Giờ làm việc</div>
                            <div class="text-muted">Thứ 2 - Thứ 7: 8:00 - 21:00</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="p-4" style="background:#fff;border:1px solid rgba(15,23,42,.06);border-radius:14px;box-shadow:var(--shop-shadow)">
                <h5 style="font-weight:900">Gửi tin nhắn</h5>
                <form class="mt-3">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Họ tên</label>
                        <input class="form-control" placeholder="Nhập tên của bạn" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Email</label>
                        <input class="form-control" placeholder="Nhập email" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Nội dung</label>
                        <textarea class="form-control" rows="5" placeholder="Nội dung tin nhắn..."></textarea>
                    </div>
                    <button type="button" class="btn btn-shop-primary">
                        <i class="bi bi-send me-1"></i>
                        Gửi tin nhắn
                    </button>
                </form>
                <div class="text-muted mt-2" style="font-size:13px">
                    (Demo giao diện) Chưa tích hợp xử lý gửi dữ liệu.
                </div>
            </div>
        </div>
    </div>
</div>

