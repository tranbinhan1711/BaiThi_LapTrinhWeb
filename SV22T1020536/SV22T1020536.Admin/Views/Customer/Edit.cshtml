@model Customer
@using SV22T1020536.Models.DataDictionary
@{
    ViewBag.Title = "Cập nhật khách hàng";
    var provinces = ViewBag.Provinces as List<Province> ?? new List<Province>();
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Customer" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-people me-2"></i>
                    Thông tin khách hàng #@Model.CustomerID
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" asp-action="Edit" asp-route-id="@Model.CustomerID" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="CustomerID" />
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <div class="row align-items-end">
                        <div class="col-md-5 mb-3">
                            <label asp-for="CustomerName" class="form-label">Tên khách hàng <span class="text-danger">*</span></label>
                            <input asp-for="CustomerName" class="form-control" autofocus />
                            <span asp-validation-for="CustomerName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label asp-for="ContactName" class="form-label">Tên giao dịch <span class="text-danger">*</span></label>
                            <input asp-for="ContactName" class="form-control" />
                            <span asp-validation-for="ContactName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-2 mb-3">
                            <label class="form-label d-block">Trạng thái</label>
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsLocked" />
                                <label class="form-check-label" asp-for="IsLocked">Khóa tài khoản</label>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label asp-for="Phone" class="form-label">Điện thoại <span class="text-danger">*</span></label>
                            <input asp-for="Phone" class="form-control" type="tel" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-md-7 mb-3">
                            <label asp-for="Email" class="form-label">Email <span class="text-danger">*</span></label>
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Địa chỉ</label>
                        <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Province" class="form-label">Tỉnh / Thành</label>
                        <select asp-for="Province" class="form-select">
                            <option value="">-- Chọn tỉnh / thành --</option>
                            @foreach (var p in provinces)
                            {
                                <option value="@p.ProvinceName">@p.ProvinceName</option>
                            }
                        </select>
                    </div>

                    <p class="text-muted small mb-0">
                        Đổi mật khẩu: dùng mục <a href="~/Customer/ChangePassword/@Model.CustomerID">Thay đổi mật khẩu</a>.
                    </p>
                </form>
            </div>
        </div>
    </div>
</div>
