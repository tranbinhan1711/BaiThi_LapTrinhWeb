@model SV22T1020536.Models.Common.PagedResult<SV22T1020536.Models.Sales.OrderViewInfo>
@using SV22T1020536.Models.Sales
@{
    Layout = null;
}
@functions {
    private static string StatusBadgeClass(OrderStatusEnum s) => s switch
    {
        OrderStatusEnum.New => "bg-warning text-dark",
        OrderStatusEnum.Accepted => "bg-info",
        OrderStatusEnum.Shipping => "bg-primary",
        OrderStatusEnum.Completed => "bg-success",
        OrderStatusEnum.Rejected or OrderStatusEnum.Cancelled => "bg-danger",
        _ => "bg-secondary"
    };
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> đơn hàng. Trang <strong>@Model.Page/@Model.PageCount</strong>
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th>Ngày đặt hàng</th>
                    <th>Tên khách hàng</th>
                    <th>Điện thoại</th>
                    <th>Ngày duyệt</th>
                    <th>Nhân viên xử lý</th>
                    <th class="text-center" style="width:160px;">Trạng thái</th>
                    <th class="text-center" style="width:40px"></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td>@item.OrderTime.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@item.CustomerName</td>
                        <td>@item.CustomerPhone</td>
                        <td>@(item.AcceptTime.HasValue ? item.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm") : "—")</td>
                        <td>@(string.IsNullOrEmpty(item.EmployeeName) ? "—" : item.EmployeeName)</td>
                        <td class="text-center">
                            <span class="badge @StatusBadgeClass(item.Status)">@item.Status.GetDescription()</span>
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Order/Detail/@item.OrderID" class="btn btn-sm btn-primary">
                                <i class="bi bi-receipt"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        @if (Model.PageCount > 1)
        {
            <ul class="pagination justify-content-center mb-0">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.Page == 0)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else if (p.IsCurrent)
                    {
                        <li class="page-item active"><span class="page-link">@p.Page</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;" onclick="doSearch(@p.Page)">@p.Page</a>
                        </li>
                    }
                }
            </ul>
        }
    </div>
</div>
