@model PosCartClearConfirmModel
@{
    ViewBag.Title = "Xóa giỏ hàng";
    var idx = 0;
}
@section PageToolBar {
    <button type="submit" form="formClearPosCart" class="btn btn-danger">
        <i class="bi bi-trash me-1"></i>
        Xóa giỏ hàng
    </button>
    <a asp-action="Create" asp-route-searchValue="@Model.SearchValue" asp-route-page="@Model.Page" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa giỏ hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formClearPosCart" asp-action="ClearPosCart" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="searchValue" value="@Model.SearchValue" />
                    <input type="hidden" name="page" value="@Model.Page" />

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2"></i>
                        Bạn có chắc chắn muốn xóa tất cả các mặt hàng trong giỏ hàng không?
                    </div>

                    <div class="table-responsive">
                        <table class="table table-bordered table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th class="text-center">#</th>
                                    <th>Tên hàng</th>
                                    <th class="text-center">ĐVT</th>
                                    <th class="text-end">SL</th>
                                    <th class="text-end">Giá</th>
                                    <th class="text-end">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var line in Model.Cart)
                                {
                                    idx++;
                                    <tr>
                                        <td class="text-center">@idx</td>
                                        <td>@line.ProductName</td>
                                        <td class="text-center">@line.Unit</td>
                                        <td class="text-end">@line.Quantity</td>
                                        <td class="text-end">@line.SalePrice.ToString("N0")</td>
                                        <td class="text-end">@line.TotalPrice.ToString("N0")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr>
                                    <th colspan="5" class="text-end">Tổng cộng:</th>
                                    <th class="text-end">@Model.CartTotal.ToString("N0")</th>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
