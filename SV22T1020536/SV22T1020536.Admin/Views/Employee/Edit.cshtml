@model Employee
@{
    ViewData["Title"] = "Sửa nhân viên";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-person-badge me-2"></i>
                    Thông tin nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" asp-action="Edit" asp-route-id="@Model.EmployeeID" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="EmployeeID" />
                    <input type="hidden" asp-for="Photo" />
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <div class="row mb-3">
                        <label asp-for="FullName" class="col-sm-3 col-form-label">Họ và tên</label>
                        <div class="col-sm-5">
                            <input asp-for="FullName" class="form-control" autofocus />
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>
                        <label asp-for="BirthDate" class="col-sm-2 col-form-label text-end">Ngày sinh</label>
                        <div class="col-sm-2">
                            <input asp-for="BirthDate" class="form-control" type="date" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Address" class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <textarea asp-for="Address" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Phone" class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-2">
                            <input asp-for="Phone" class="form-control" type="tel" />
                        </div>
                        <label asp-for="Email" class="col-sm-1 col-form-label text-end">Email</label>
                        <div class="col-sm-6">
                            <input asp-for="Email" class="form-control" type="email" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" for="photoFile">Ảnh đại diện</label>
                        <div class="col-sm-9">
                            @if (!string.IsNullOrWhiteSpace(Model.Photo))
                            {
                                <div class="mb-2">
                                    <img src="@Url.Content("~/images/employees/" + Uri.EscapeDataString(Model.Photo))" class="img-thumbnail" style="max-height:120px" alt="" onerror="this.style.display='none'" />
                                    <div class="form-text">Ảnh hiện tại. Chọn file mới để thay thế.</div>
                                </div>
                            }
                            <input type="file" name="photoFile" id="photoFile" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp,image/bmp,.jpg,.jpeg,.png,.gif,.webp,.bmp" />
                            @Html.ValidationMessage("photoFile", "", new { @class = "text-danger small d-block" })
                            <div class="form-text">Tối đa 5 MB. Để trống nếu giữ ảnh cũ.</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="RoleNames" class="col-sm-3 col-form-label">Chức vụ</label>
                        <div class="col-sm-9">
                            <select asp-for="RoleNames" class="form-select">
                                <option value="">-- Chọn chức vụ --</option>
                                <option value="Staff">Nhân viên</option>
                                <option value="Manager">Quản lý</option>
                                <option value="Admin">Quản trị viên</option>
                            </select>
                            <span asp-validation-for="RoleNames" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsWorking" />
                                <label class="form-check-label" asp-for="IsWorking">Đang làm việc</label>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
