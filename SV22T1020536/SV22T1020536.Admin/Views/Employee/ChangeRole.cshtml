@model Employee
@{
    ViewBag.Title = "Phân quyền nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formChangeRole" class="btn btn-primary">
        <i class="bi bi-shield-check me-1"></i>
        Lưu phân quyền
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-shield-check me-2"></i>
                    Phân quyền cho nhân viên
                </h5>
            </div>

            <div class="card-body">
                <form id="formChangeRole" asp-action="ChangeRole" asp-route-id="@Model.EmployeeID" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <fieldset class="mb-4">
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-person me-1"></i>
                            Thông tin nhân viên
                        </legend>

                        <dl class="row mb-0">
                            <dt class="col-sm-3">Họ và tên</dt>
                            <dd class="col-sm-9">@Model.FullName</dd>

                            <dt class="col-sm-3">Email</dt>
                            <dd class="col-sm-9">@Model.Email</dd>

                            <dt class="col-sm-3">Trạng thái</dt>
                            <dd class="col-sm-9">
                                @if (Model.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </dd>
                        </dl>
                    </fieldset>

                    <fieldset>
                        <legend class="fs-6 text-muted mb-3">
                            <i class="bi bi-shield-lock me-1"></i>
                            Chức vụ / quyền
                        </legend>

                        <div class="mb-3">
                            <label class="form-label" for="roleNames">Chọn chức vụ</label>
                            <select class="form-select" id="roleNames" name="roleNames">
                                <option value="">-- Chọn --</option>
                                @if (Model.RoleNames == "Staff")
                                {
                                    <option value="Staff" selected>Nhân viên</option>
                                }
                                else
                                {
                                    <option value="Staff">Nhân viên</option>
                                }
                                @if (Model.RoleNames == "Manager")
                                {
                                    <option value="Manager" selected>Quản lý</option>
                                }
                                else
                                {
                                    <option value="Manager">Quản lý</option>
                                }
                                @if (Model.RoleNames == "Admin")
                                {
                                    <option value="Admin" selected>Quản trị viên</option>
                                }
                                else
                                {
                                    <option value="Admin">Quản trị viên</option>
                                }
                            </select>
                        </div>
                    </fieldset>

                </form>
            </div>
        </div>
    </div>
</div>
