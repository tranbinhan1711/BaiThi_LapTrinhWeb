@model Product
@{
    ViewData["Title"] = "Sửa mặt hàng";
    var categories = ViewBag.Categories as IList<Category> ?? new List<Category>();
    var suppliers = ViewBag.Suppliers as IList<Supplier> ?? new List<Supplier>();
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu dữ liệu
    </button>

    <a asp-action="Delete" asp-route-id="@Model.ProductID" class="btn btn-outline-danger ms-1">
        <i class="bi bi-trash"></i>
        Xóa
    </a>

    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

@if (TempData["SuccessMessage"] is string successMsg && !string.IsNullOrWhiteSpace(successMsg))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i>
                    Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" asp-action="Edit" asp-route-id="@Model.ProductID" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="Photo" />
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <div class="row mb-3">
                        <label asp-for="ProductName" class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input asp-for="ProductName" class="form-control" autofocus />
                            <span asp-validation-for="ProductName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-3">
                            <select asp-for="CategoryID" class="form-select">
                                <option value="">-- Chọn loại hàng --</option>
                                @foreach (var c in categories)
                                {
                                    <option value="@c.CategoryID">@c.CategoryName</option>
                                }
                            </select>
                            <span asp-validation-for="CategoryID" class="text-danger small"></span>
                        </div>

                        <label class="col-sm-2 col-form-label text-end">Nhà cung cấp</label>
                        <div class="col-sm-4">
                            <select asp-for="SupplierID" class="form-select">
                                <option value="">-- Chọn nhà cung cấp --</option>
                                @foreach (var s in suppliers)
                                {
                                    <option value="@s.SupplierID">@s.SupplierName</option>
                                }
                            </select>
                            <span asp-validation-for="SupplierID" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="Unit" class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-3">
                            <input asp-for="Unit" class="form-control" />
                            <span asp-validation-for="Unit" class="text-danger small"></span>
                        </div>

                        <label asp-for="Price" class="col-sm-2 col-form-label text-end">Giá</label>
                        <div class="col-sm-4">
                            <input asp-for="Price" class="form-control" type="number" step="0.01" min="0" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" asp-for="IsSelling" />
                                <label class="form-check-label" asp-for="IsSelling">Đang bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label" for="photoFile">Ảnh đại diện</label>
                        <div class="col-sm-9">
                            @{
                                var editPreview = ProductPhotos.ResolveVirtualPath(Model.Photo, Model.ProductName);
                            }
                            @if (!string.IsNullOrWhiteSpace(editPreview))
                            {
                                <div class="mb-2">
                                    <img src="@Url.Content(editPreview)" class="img-thumbnail" style="max-height:120px" alt="" />
                                    <div class="form-text">Ảnh hiện tại. Chọn file mới bên dưới để thay thế.</div>
                                </div>
                            }
                            <input type="file" name="photoFile" id="photoFile" class="form-control" accept="image/jpeg,image/png,image/gif,image/webp,image/bmp,.jpg,.jpeg,.png,.gif,.webp,.bmp" />
                            @Html.ValidationMessage("photoFile", "", new { @class = "text-danger small d-block" })
                            <div class="form-text">Tối đa 5 MB. Để nguyên nếu không đổi ảnh.</div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label asp-for="ProductDescription" class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea asp-for="ProductDescription" class="form-control" rows="4"></textarea>
                        </div>
                    </div>

                </form>
            </div>
        </div>

        <p class="text-muted small mt-4 mb-2">Quản lý bổ sung cho mặt hàng này:</p>
        <div class="row g-3">
            <div class="col-md-6">
                <a asp-action="ListPhotos" asp-route-id="@Model.ProductID" class="card card-outline card-primary shadow-sm text-decoration-none text-body h-100 border-top border-primary border-3">
                    <div class="card-body d-flex align-items-center py-4">
                        <span class="display-6 text-primary me-3"><i class="bi bi-images"></i></span>
                        <div class="flex-grow-1">
                            <h5 class="mb-1">Thư viện ảnh</h5>
                            <small class="text-muted">Xem danh sách, thêm / sửa / xóa ảnh album</small>
                        </div>
                        <i class="bi bi-chevron-right text-muted fs-4"></i>
                    </div>
                </a>
            </div>
            <div class="col-md-6">
                <a asp-action="ListAttributes" asp-route-id="@Model.ProductID" class="card card-outline card-success shadow-sm text-decoration-none text-body h-100 border-top border-success border-3">
                    <div class="card-body d-flex align-items-center py-4">
                        <span class="display-6 text-success me-3"><i class="bi bi-list-check"></i></span>
                        <div class="flex-grow-1">
                            <h5 class="mb-1">Thuộc tính mặt hàng</h5>
                            <small class="text-muted">Màu sắc, kích thước, chất liệu…</small>
                        </div>
                        <i class="bi bi-chevron-right text-muted fs-4"></i>
                    </div>
                </a>
            </div>
        </div>
    </div>
</div>
