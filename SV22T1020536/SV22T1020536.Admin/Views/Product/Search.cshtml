@model SV22T1020536.Models.Common.PagedResult<SV22T1020536.Models.Catalog.Product>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> mặt hàng. Trang <strong>@Model.Page/@Model.PageCount</strong>
</div>

<div class="card">
    <div class="card-body p-1">
        <table class="table table-bordered table-hover mb-0 align-middle">
            <thead class="table-secondary">
                <tr>
                    <th style="width:80px;">Ảnh</th>
                    <th>Mặt hàng</th>
                    <th style="width:120px;">Đơn vị</th>
                    <th style="width:120px;">Giá</th>
                    <th class="text-center" style="width:140px;">Trạng thái</th>
                    <th class="text-center" style="width:100px;">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.DataItems)
                {
                    <tr>
                        <td class="text-center">
                            @{
                                var rowPhoto = ProductPhotos.ResolveVirtualPath(item.Photo, item.ProductName);
                            }
                            @if (!string.IsNullOrWhiteSpace(rowPhoto))
                            {
                                <img src="@Url.Content(rowPhoto)"
                                     class="img-thumbnail"
                                     alt=""
                                     style="max-height:48px;" />
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                        <td>
                            <strong>@item.ProductName</strong><br />
                            <small class="text-muted">@(item.ProductDescription ?? "")</small>
                        </td>
                        <td>@item.Unit</td>
                        <td class="text-end">@item.Price.ToString("N0")</td>
                        <td class="text-center">
                            @if (item.IsSelling)
                            {
                                <span class="badge bg-success">Đang bán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Ngừng bán</span>
                            }
                        </td>
                        <td class="text-center text-nowrap">
                            <a href="~/Product/Edit/@item.ProductID" class="btn btn-sm btn-primary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <a asp-controller="Product"
                               asp-action="Delete"
                               asp-route-id="@item.ProductID"
                               class="btn btn-sm btn-danger"
                               title="Xóa mặt hàng">
                                <i class="bi bi-trash"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card-footer">
        @if (Model.PageCount > 1)
        {
            <ul class="pagination justify-content-center mb-0">
                @foreach (var p in Model.GetDisplayPages())
                {
                    if (p.Page == 0)
                    {
                        <li class="page-item disabled"><span class="page-link">...</span></li>
                    }
                    else if (p.IsCurrent)
                    {
                        <li class="page-item active"><span class="page-link">@p.Page</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;" onclick="doSearch(@p.Page)">@p.Page</a>
                        </li>
                    }
                }
            </ul>
        }
    </div>
</div>
