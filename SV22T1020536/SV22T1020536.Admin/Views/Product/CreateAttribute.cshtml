@model Product
@section PageToolBar {
    <button type="submit" form="formCreateAttr" class="btn btn-primary">
        <i class="bi bi-save"></i>
        Lưu
    </button>
    <a asp-action="ListAttributes" asp-route-id="@Model.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12 col-xl-10">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-list-check me-2"></i>
                    Bổ sung thuộc tính cho mặt hàng — <strong>@Model.ProductName</strong>
                </h5>
            </div>
            <form id="formCreateAttr" asp-action="CreateAttribute" asp-route-id="@Model.ProductID" method="post">
                @Html.AntiForgeryToken()
                <div class="card-body">
                    <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>

                    <div class="mb-3">
                        <label for="attributeName" class="form-label">Tên thuộc tính <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="attributeName" name="attributeName" placeholder="VD: Màu sắc, Kích thước, Chất liệu..." required maxlength="255" autofocus />
                    </div>
                    <div class="mb-3">
                        <label for="attributeValue" class="form-label">Giá trị <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="attributeValue" name="attributeValue" placeholder="VD: Đỏ, XL, Cotton..." required maxlength="500" />
                    </div>
                    <div class="mb-0">
                        <label for="displayOrder" class="form-label">Thứ tự hiển thị</label>
                        <input type="number" class="form-control" style="max-width:12rem" id="displayOrder" name="displayOrder" value="0" />
                    </div>
                </div>
                <div class="card-footer">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-save"></i> Lưu thuộc tính
                    </button>
                    <a asp-action="ListAttributes" asp-route-id="@Model.ProductID" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> Hủy bỏ
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
