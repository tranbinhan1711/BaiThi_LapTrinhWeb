@{
    var product = ViewBag.Product as Product ?? throw new InvalidOperationException("Thiếu ViewBag.Product");
    var attributes = ViewBag.Attributes as IList<ProductAttribute> ?? new List<ProductAttribute>();
}
@section PageToolBar {
    <a asp-action="CreateAttribute" asp-route-id="@product.ProductID" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>
        Thêm thuộc tính
    </a>
    <a asp-action="Edit" asp-route-id="@product.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left me-1"></i>
        Quay lại
    </a>
}

@if (TempData["SuccessMessage"] is string sm && !string.IsNullOrWhiteSpace(sm))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @sm
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-list-check me-2"></i>
                    Thuộc tính mặt hàng — <strong>@product.ProductName</strong>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>Tên thuộc tính</th>
                                <th>Giá trị</th>
                                <th style="width:110px" class="text-center">Thứ tự</th>
                                <th style="width:120px" class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (attributes.Count == 0)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-4">
                                        Chưa có thuộc tính. Nhấn
                                        <a asp-action="CreateAttribute" asp-route-id="@product.ProductID" class="fw-semibold">Thêm thuộc tính</a>
                                        để bổ sung.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var a in attributes)
                                {
                                    <tr>
                                        <td>@a.AttributeName</td>
                                        <td>@a.AttributeValue</td>
                                        <td class="text-center">@a.DisplayOrder</td>
                                        <td class="text-center text-nowrap">
                                            <a class="btn btn-sm btn-outline-primary" asp-action="EditAttribute" asp-route-id="@product.ProductID" asp-route-attributeId="@a.AttributeID" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-danger" asp-action="DeleteAttribute" asp-route-id="@product.ProductID" asp-route-attributeId="@a.AttributeID" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
