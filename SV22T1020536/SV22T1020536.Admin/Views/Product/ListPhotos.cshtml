@{
    var product = ViewBag.Product as Product;
    var photos = ViewBag.Photos as IList<ProductPhoto> ?? new List<ProductPhoto>();
    if (product == null) { throw new InvalidOperationException("Thiếu ViewBag.Product"); }
}
@section PageToolBar {
    <a asp-action="CreatePhoto" asp-route-id="@product.ProductID" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Thêm ảnh
    </a>
    <a asp-action="Edit" asp-route-id="@product.ProductID" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left me-1"></i>
        Quay lại
    </a>
}

@if (TempData["SuccessMessage"] is string sm && !string.IsNullOrWhiteSpace(sm))
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @sm
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Đóng"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-images me-2"></i>
                    Thư viện ảnh — <strong>@product.ProductName</strong>
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover table-bordered mb-0 align-middle">
                        <thead class="table-light">
                            <tr>
                                <th style="width:110px" class="text-center">Ảnh</th>
                                <th>Mô tả / tiêu đề</th>
                                <th style="width:100px" class="text-center">Thứ tự</th>
                                <th style="width:110px" class="text-center">Hiển thị</th>
                                <th style="width:120px" class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (photos.Count == 0)
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted py-4">
                                        Chưa có ảnh trong thư viện. Nhấn
                                        <a asp-action="CreatePhoto" asp-route-id="@product.ProductID" class="fw-semibold">Thêm ảnh</a>
                                        để tải lên.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var p in photos)
                                {
                                    var imgUrl = ProductPhotos.ResolveVirtualPath(p.Photo, product.ProductName);
                                    <tr>
                                        <td class="text-center">
                                            @if (!string.IsNullOrWhiteSpace(imgUrl))
                                            {
                                                <img src="@Url.Content(imgUrl)" class="img-thumbnail" style="max-height:72px;max-width:88px;object-fit:cover" alt="" />
                                            }
                                            else
                                            {
                                                <span class="text-muted small">—</span>
                                            }
                                        </td>
                                        <td>@p.Description</td>
                                        <td class="text-center">@p.DisplayOrder</td>
                                        <td class="text-center">
                                            @if (p.IsHidden)
                                            {
                                                <span class="badge bg-secondary">Ẩn</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">Hiện</span>
                                            }
                                        </td>
                                        <td class="text-center text-nowrap">
                                            <a class="btn btn-sm btn-outline-primary" asp-action="EditPhoto" asp-route-id="@product.ProductID" asp-route-photoId="@p.PhotoID" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-danger" asp-action="DeletePhoto" asp-route-id="@product.ProductID" asp-route-photoId="@p.PhotoID" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
