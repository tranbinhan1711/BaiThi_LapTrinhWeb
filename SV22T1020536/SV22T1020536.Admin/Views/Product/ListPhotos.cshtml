@{
    Layout = null;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/123">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th style="width:120px">Ảnh</th>
                            <th>Mô tả</th>
                            <th style="width:120px" class="text-center">Thứ tự</th>
                            <th style="width:120px">Hiển thị</th>
                            <th style="width:100px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        @for (int i = 1; i <= 5; i++)
                        {
                            <tr>
                                <td class="text-center">
                                    <img src="~/images/products/demo.png"
                                    class="img-thumbnail"
                                    style="max-height:80px;" />
                                </td>
                                <td>Ảnh mặt trước sản phẩm</td>
                                <td class="text-center">@i</td>
                                <td class="text-center">
                                    <span class="badge bg-success">Hiện</span>
                                </td>
                                <td class="text-center text-nowrap">
                                    <a class="btn btn-sm btn-primary" href="~/Product/EditPhoto/123?photoId=456">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a class="btn btn-sm btn-danger" href="~/Product/DeletePhoto/123?photoId=456">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>