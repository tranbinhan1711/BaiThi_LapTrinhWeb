@model Supplier
@using SV22T1020536.Models.DataDictionary
@{
    ViewData["Title"] = "Thêm nhà cung cấp";
    var provinces = ViewBag.Provinces as List<Province> ?? new List<Province>();
}

<div class="card card-primary card-outline mb-4">
    <div class="card-header">
        <h3 class="card-title">Thêm nhà cung cấp mới</h3>
    </div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="SupplierName" class="form-label">Tên nhà cung cấp: <span class="text-danger">*</span></label>
                        <input asp-for="SupplierName" class="form-control" />
                        <span asp-validation-for="SupplierName" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="ContactName" class="form-label">Tên giao dịch: <span class="text-danger">*</span></label>
                        <input asp-for="ContactName" class="form-control" />
                        <span asp-validation-for="ContactName" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Phone" class="form-label">Điện thoại: <span class="text-danger">*</span></label>
                        <input asp-for="Phone" class="form-control" type="tel" />
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email:</label>
                        <input asp-for="Email" class="form-control" type="email" />
                    </div>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Address" class="form-label">Địa chỉ:</label>
                <textarea asp-for="Address" class="form-control" rows="3"></textarea>
            </div>

            <div class="mb-3">
                <label asp-for="Province" class="form-label">Tỉnh/Thành phố:</label>
                <select asp-for="Province" class="form-select">
                    <option value="">-- Chọn tỉnh/thành --</option>
                    @foreach (var p in provinces)
                    {
                        <option value="@p.ProvinceName">@p.ProvinceName</option>
                    }
                </select>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Lưu thông tin
            </button>
            <a href="~/Supplier" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i> Hủy bỏ
            </a>
        </div>
    </form>
</div>
