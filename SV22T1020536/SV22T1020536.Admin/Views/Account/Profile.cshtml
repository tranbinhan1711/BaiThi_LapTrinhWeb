@{
    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">Thông tin hồ sơ</h3>
    </div>
    <div class="card-body">
        <form onsubmit="event.preventDefault()">
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="fullName" class="form-label">Họ tên:</label>
                        <input type="text" class="form-control" id="fullName" name="fullName" value="Admin User">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="email" class="form-label">Email:</label>
                        <input type="email" class="form-control" id="email" name="email" value="admin@liteshop.vn">
                    </div>
                </div>
            </div>
            <div class="row">
                <div class="col-md-6">
                    <div class="mb-3">
                        <label for="phone" class="form-label">Điện thoại:</label>
                        <input type="tel" class="form-control" id="phone" name="phone" value="0912345678">
                    </div>
                </div>
            </div>
            <div class="mb-3">
                <label for="address" class="form-label">Địa chỉ:</label>
                <input type="text" class="form-control" id="address" name="address">
            </div>
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Lưu thay đổi
            </button>
        </form>
    </div>
</div>
