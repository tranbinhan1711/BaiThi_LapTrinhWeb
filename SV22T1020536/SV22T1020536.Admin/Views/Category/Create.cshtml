@model Category
@{
    ViewData["Title"] = "Thêm loại hàng";
}

<div class="card card-primary card-outline mb-4">
    <div class="card-header">
        <h3 class="card-title">Thêm loại hàng mới</h3>
    </div>
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="All" class="alert alert-danger" role="alert"></div>
        <div class="card-body">
            <div class="mb-3">
                <label asp-for="CategoryName" class="form-label">Tên loại hàng: <span class="text-danger">*</span></label>
                <input asp-for="CategoryName" class="form-control" />
                <span asp-validation-for="CategoryName" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Mô tả:</label>
                <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nhập mô tả cho loại hàng..."></textarea>
            </div>
        </div>
        <div class="card-footer">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-save"></i> Lưu thông tin
            </button>
            <a href="~/Category" class="btn btn-secondary">
                <i class="bi bi-x-circle"></i> Hủy bỏ
            </a>
        </div>
    </form>
</div>
